3.2 Sensitive Config — Encryption

IdP configurations include client secrets (OIDC) and signing certificates (SAML). These must never be stored in plaintext. The config_encrypted column stores AES-256-GCM encrypted JSON.



// Example decrypted content of config_encrypted (OIDC type)

{

  "authorization_url": "https://acme.okta.com/oauth2/v1/authorize",

  "token_url": "https://acme.okta.com/oauth2/v1/token",

  "user_info_url": "https://acme.okta.com/oauth2/v1/userinfo",

  "jwks_url": "https://acme.okta.com/oauth2/v1/keys",

  "client_id": "0oa1abc2defGHIJK",

  "client_secret": "super_secret_value",

  "scopes": ["openid", "profile", "email", "groups"],

  "issuer": "https://acme.okta.com"

}



// Example decrypted content (SAML type)

{

  "single_sign_on_service_url": "https://acme.okta.com/app/saml/sso",

  "single_logout_service_url": "https://acme.okta.com/app/saml/slo",

  "idp_entity_id": "http://www.okta.com/exk1abc2def",

  "signing_certificate": "MIIC...base64...",

  "name_id_policy_format": "urn:oasis:names:tc:SAML:1.1:nameid-format:emailAddress",

  "want_assertions_signed": true,

  "validate_signature": true

}



3.3 Attribute Mapper JSON Structure

// attribute_mappers column

[

  {

    "id": "map_email",

    "mapper_type": "oidc-user-attribute-idp-mapper",

    "upstream_claim": "email",

    "user_attribute": "email",

    "sync_mode": "inherit"

  },

  {

    "id": "map_firstname",

    "mapper_type": "oidc-user-attribute-idp-mapper",

    "upstream_claim": "given_name",

    "user_attribute": "firstName",

    "sync_mode": "inherit"

  },

  {

    "id": "map_groups",

    "mapper_type": "oidc-role-idp-mapper",

    "upstream_claim": "groups",

    "role": "tenant_admin",

    "claim_value": "foundry-admins",

    "sync_mode": "force"

  }

]





