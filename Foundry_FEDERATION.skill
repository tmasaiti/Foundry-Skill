4.1 POST /v1/workspaces/:id/identity-providers — Request Shapes

OIDC Enterprise (Okta, Auth0, any OIDC)

{

  "alias": "acme-okta",

  "display_name": "Sign in with Acme Corp",

  "type": "oidc",

  "config": {

    "authorization_url": "https://acme.okta.com/oauth2/v1/authorize",

    "token_url": "https://acme.okta.com/oauth2/v1/token",

    "user_info_url": "https://acme.okta.com/oauth2/v1/userinfo",

    "jwks_url": "https://acme.okta.com/oauth2/v1/keys",

    "issuer": "https://acme.okta.com",

    "client_id": "0oa1abc2defGHIJK",

    "client_secret": "super_secret",

    "scopes": ["openid", "profile", "email", "groups"],

    "pkce": true

  },

  "domain_hints": ["acme.com"],

  "hide_on_login_page": false,

  "attribute_mappers": [

    { "upstream_claim": "email", "user_attribute": "email" },

    { "upstream_claim": "given_name", "user_attribute": "firstName" },

    { "upstream_claim": "family_name", "user_attribute": "lastName" }

  ]

}



SAML Enterprise (Azure AD, ADFS)

{

  "alias": "acme-azure",

  "display_name": "Sign in with Acme Corp",

  "type": "saml",

  "config": {

    "single_sign_on_service_url": "https://login.microsoftonline.com/{tenant}/saml2",

    "single_logout_service_url": "https://login.microsoftonline.com/{tenant}/saml2",

    "idp_entity_id": "https://sts.windows.net/{tenant}/",

    "signing_certificate": "MIIC...base64...",

    "name_id_policy_format": "urn:oasis:names:tc:SAML:1.1:nameid-format:emailAddress",

    "want_assertions_signed": true,

    "validate_signature": true,

    "sign_sp_metadata": false

  },

  "domain_hints": ["acme.com"],

  "attribute_mappers": [

    { "upstream_claim": "http://schemas.xmlsoap.org/ws/2005/05/identity/claims/emailaddress", "user_attribute": "email" },

    { "upstream_claim": "http://schemas.xmlsoap.org/ws/2005/05/identity/claims/givenname", "user_attribute": "firstName" }

  ]

}



Google / GitHub (Social — simplified)

// Google

{

  "alias": "google",

  "display_name": "Sign in with Google",

  "type": "google",

  "config": {

    "client_id": "GOOGLE_CLIENT_ID.apps.googleusercontent.com",

