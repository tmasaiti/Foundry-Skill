4.2 Docker Compose — Full Dev Environment

The complete docker-compose.yml below brings up all seven services with a single command: docker compose up. No pre-configuration required beyond copying .env.example to .env.

# docker-compose.yml

# Usage: docker compose up --build



version: '3.9'



networks:

  foundry:

    driver: bridge



volumes:

  postgres_data:

  redis_data:

  keycloak_data:



services:



  # ─── POSTGRES ──────────────────────────────────────────────────

  postgres:

    image: postgres:16-alpine

    container_name: foundry_postgres

    restart: unless-stopped

    environment:

      POSTGRES_USER: ${POSTGRES_USER:-foundry}

      POSTGRES_PASSWORD: ${POSTGRES_PASSWORD:-foundry_secret}

      POSTGRES_DB: ${POSTGRES_DB:-foundry}

    volumes:

      - postgres_data:/var/lib/postgresql/data

      - ./postgres/init:/docker-entrypoint-initdb.d

    ports:

      - '5432:5432'

    networks: [foundry]

    healthcheck:

      test: ['CMD-SHELL', 'pg_isready -U foundry']

      interval: 10s

      timeout: 5s

      retries: 5



  # ─── REDIS ─────────────────────────────────────────────────────

  redis:

    image: redis:7-alpine

    container_name: foundry_redis

    restart: unless-stopped

    command: redis-server /usr/local/etc/redis/redis.conf

    volumes:

      - redis_data:/data

      - ./redis/redis.conf:/usr/local/etc/redis/redis.conf

    ports:

      - '6379:6379'

    networks: [foundry]

    healthcheck:

      test: ['CMD', 'redis-cli', 'ping']

      interval: 10s

      timeout: 5s

      retries: 3



  # ─── MAILPIT ───────────────────────────────────────────────────

  mailpit:

    image: axllent/mailpit:latest

    container_name: foundry_mailpit

    restart: unless-stopped

    ports:

      - '1025:1025'  # SMTP

      - '8025:8025'  # Web UI

    networks: [foundry]



  # ─── KEYCLOAK ──────────────────────────────────────────────────

  keycloak:

    build:

      context: ./keycloak

      dockerfile: Dockerfile

    container_name: foundry_keycloak

    restart: unless-stopped

    depends_on:

      postgres:

        condition: service_healthy

    environment:

      KC_DB: postgres

      KC_DB_URL: jdbc:postgresql://postgres:5432/foundry?currentSchema=keycloak

      KC_DB_USERNAME: ${POSTGRES_USER:-foundry}

      KC_DB_PASSWORD: ${POSTGRES_PASSWORD:-foundry_secret}

      KC_HOSTNAME: ${KC_HOSTNAME:-localhost}

      KC_HOSTNAME_PORT: '8080'

      KC_HOSTNAME_STRICT: 'false'

      KC_HTTP_ENABLED: 'true'

      KEYCLOAK_ADMIN: ${KC_ADMIN:-admin}

      KEYCLOAK_ADMIN_PASSWORD: ${KC_ADMIN_PASSWORD:-admin_secret}

      KC_LOG_LEVEL: ${KC_LOG_LEVEL:-INFO}

    ports:

      - '8080:8080'

    networks: [foundry]

    healthcheck:

      test: ['CMD-SHELL', 'curl -sf http://localhost:8080/health/ready || exit 1']

      interval: 15s

      timeout: 10s

      retries: 10

      start_period: 60s



  # ─── API (Control Plane) ───────────────────────────────────────

  api:

    build:

      context: ./api

      dockerfile: Dockerfile

      target: development

    container_name: foundry_api

    restart: unless-stopped

    depends_on:

      postgres:

        condition: service_healthy

      redis:

        condition: service_healthy

      keycloak:

        condition: service_healthy

    environment:

      NODE_ENV: development

      DATABASE_URL: postgresql://${POSTGRES_USER}:${POSTGRES_PASSWORD}@postgres:5432/foundry?schema=control_plane

      REDIS_URL: redis://redis:6379

      KC_BASE_URL: http://keycloak:8080

      KC_ADMIN_USER: ${KC_ADMIN:-admin}

      KC_ADMIN_PASSWORD: ${KC_ADMIN_PASSWORD:-admin_secret}

      KC_PUBLIC_BASE_URL: ${KC_PUBLIC_BASE_URL:-http://localhost:8080}

      STRIPE_SECRET_KEY: ${STRIPE_SECRET_KEY}

      STRIPE_WEBHOOK_SECRET: ${STRIPE_WEBHOOK_SECRET}

      SMTP_HOST: mailpit

      SMTP_PORT: '1025'

      SMTP_FROM: noreply@foundry-iam.local

      JWT_JWKS_URI: http://keycloak:8080/realms/foundry-saas/protocol/openid-connect/certs

      API_BASE_URL: ${API_BASE_URL:-http://localhost:3000}

      LOG_LEVEL: ${LOG_LEVEL:-debug}

    volumes:

      - ./api/src:/app/src  # Hot reload in dev

    ports:

      - '3000:3000'

    networks: [foundry]



  # ─── FRONTEND (SaaS Portal) ────────────────────────────────────

  frontend:

    build:

      context: ./frontend

      dockerfile: Dockerfile

      target: development

    container_name: foundry_frontend

    restart: unless-stopped

    depends_on: [api, keycloak]

    environment:

      VITE_API_URL: http://localhost:3000

      VITE_KC_URL: http://localhost:8080

      VITE_KC_REALM: foundry-saas

      VITE_KC_CLIENT_ID: portal-spa

    volumes:

      - ./frontend/src:/app/src  # Hot reload

    ports:

      - '5173:5173'

    networks: [foundry]



  # ─── DOCS (Developer Documentation) ───────────────────────────

  docs:

    build:

      context: ./docs

      dockerfile: Dockerfile

      target: development

    container_name: foundry_docs

    restart: unless-stopped

    volumes:

      - ./docs/docs:/app/docs  # Hot reload

    ports:

      - '4000:3000'

    networks: [foundry]



